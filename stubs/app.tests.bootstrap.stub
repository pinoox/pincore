<?php

/**
 * App test bootstrap — loads core tests and reads package from app.php.
 *
 * Loaded automatically by: php pinoox test {{package}}
 * Manual run: php vendor/bin/pest apps/{{package}}/tests --bootstrap=apps/{{package}}/tests/bootstrap.php --configuration=vendor/pinoox/pincore/phpunit.xml
 */
$platformRoot = dirname(__DIR__, 3);

require $platformRoot . '/launcher/test-paths.php';
require pinoox_core_tests_dir($platformRoot) . '/bootstrap.php';

\Pinoox\Component\Test\AppTestKit::setPackage(
    \Pinoox\Component\Test\AppTestKit::packageFromAppDir(dirname(__DIR__)),
);
