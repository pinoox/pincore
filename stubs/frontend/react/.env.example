# Optional overrides for Vite dev. `php pinoox fe dev` resolves URLs from the app router
# and injects missing VITE_* values at runtime (it does not modify this file by default).
#
# Set ENV_SERVER_SYNC=true to persist an autogenerated block on each `fe dev` run.
ENV_SERVER_SYNC=false
#
# VITE_DEV_PORT=5173
# VITE_SERVER_URL=http://127.0.0.1:8000
