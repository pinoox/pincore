# Optional overrides for Vite dev. `php pinoox fe dev` resolves URLs from the app router
# and injects missing VITE_* values at runtime (it does not modify this file by default).
#
# Set ENV_SERVER_SYNC=true to persist an autogenerated block on each `fe dev` run.
ENV_SERVER_SYNC=false
#
# Manual values (used when set; auto-detection fills gaps only at runtime):
# VITE_HOT_FILE=dist/hot
# VITE_DEV_PORT=5174
# VITE_SERVER_URL=http://127.0.0.1:8000/my-shop
# VITE_DEV_SERVER=http://127.0.0.1:5174
# VITE_DEV_PROXY=/my-shop,/api,/uploads
#
# Prefer frontend.config.php dev.server_url / dev.proxy when possible.
# Custom env file: php pinoox fe dev --env-file=.env.local
