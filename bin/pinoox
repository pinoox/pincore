#!/usr/bin/env php
<?php
/**
 * Pinoox framework CLI — finds project bootstrap.php and boots the application.
 */

$dir = __DIR__;

for ($i = 0; $i < 8; $i++) {
    if (is_file($dir . '/bootstrap.php')) {
        require $dir . '/bootstrap.php';
        exit;
    }

    $parent = dirname($dir);
    if ($parent === $dir) {
        break;
    }
    $dir = $parent;
}

fwrite(STDERR, "Pinoox: bootstrap.php not found. Run this command from a Pinoox project root.\n");
exit(1);
