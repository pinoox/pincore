{
  "name": "pinoox/pincore",
  "description": "Pinoox HMVC framework core",
  "keywords": [
    "PHP",
    "PHP Framework",
    "pinoox",
    "hmvc"
  ],
  "type": "library",
  "homepage": "https://www.pinoox.com/",
  "license": "MIT",
  "authors": [
    {
      "name": "Pinoox",
      "email": "dev@pinoox.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "pinoox/pinion": "^1.1",
    "doctrine/dbal": "^4.2",
    "firebase/php-jwt": "^7.0",
    "illuminate/database": "^12.0",
    "illuminate/events": "^12.0",
    "illuminate/filesystem": "^12.0",
    "illuminate/hashing": "^12.0",
    "illuminate/pagination": "^12.0",
    "illuminate/support": "^12.0",
    "illuminate/validation": "^12.0",
    "intervention/image": "^3.11",
    "league/flysystem": "^3.29",
    "league/flysystem-local": "^3.29",
    "league/flysystem-path-prefixing": "^3.28",
    "league/flysystem-read-only": "^3.28",
    "monolog/monolog": "^3.9",
    "morilog/jalali": "^3.4",
    "nelexa/zip": "^4.0",
    "nette/php-generator": "^4.1",
    "paragonie/sodium_compat": "^2.1",
    "phpoption/phpoption": "^1.9",
    "predis/predis": "^2.4",
    "symfony/asset": "^7.2",
    "symfony/cache": "^7.2",
    "symfony/console": "^7.2",
    "symfony/dependency-injection": "^7.2",
    "symfony/dotenv": "^7.2",
    "symfony/error-handler": "^7.2",
    "symfony/filesystem": "^7.2",
    "symfony/finder": "^7.2",
    "symfony/http-client": "^7.2",
    "symfony/http-foundation": "^7.2",
    "symfony/http-kernel": "^7.2",
    "symfony/process": "^7.2",
    "symfony/property-access": "^7.2",
    "symfony/routing": "^7.2",
    "symfony/serializer": "^7.2",
    "symfony/var-dumper": "^7.2",
    "twig/twig": "^3.14",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "Pinoox\\": ""
    },
    "files": [
      "functions/base.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Pinoox\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "nikic/php-parser": "^5.4",
    "nunomaduro/collision": "^8.5",
    "pestphp/pest": "^2.36",
    "pinoox/devdb": "^1.4"
  },
  "scripts": {
    "test": "@php vendor/bin/pest --configuration=phpunit.xml",
    "test:ci": "@php vendor/bin/pest --configuration=phpunit.ci.xml",
    "test:unit": "@php vendor/bin/pest --configuration=phpunit.xml --testsuite=Unit",
    "pincore": "@php bin/pincore"
  },
  "bin": [
    "bin/pincore"
  ],
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "suggest": {
    "ext-pdo_mysql": "Required when DB_CONNECTION is mysql or mariadb",
    "ext-pdo_pgsql": "Required when DB_CONNECTION is pgsql",
    "ext-pdo_sqlite": "Required when DB_CONNECTION is sqlite",
    "ext-pdo_sqlsrv": "Required when DB_CONNECTION is sqlsrv",
    "ext-zip": "Required for Pinx package build and install (.pinx)",
    "ext-sodium": "Recommended for faster Pinx Ed25519 signing (pure-PHP fallback ships with pincore)"
  },
  "minimum-stability": "dev",
  "extra": {
    "branch-alias": {
      "dev-master": "3.x-dev"
    }
  },
  "prefer-stable": true
}
