{
  "name": "pinoox/pincore",
  "description": "Pinoox HMVC framework core",
  "keywords": [
    "PHP",
    "PHP Framework",
    "pinoox",
    "hmvc"
  ],
  "type": "library",
  "homepage": "https://www.pinoox.com/",
  "license": "MIT",
  "authors": [
    {
      "name": "Pinoox",
      "email": "dev@pinoox.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "pinoox/pinion": "^1.0",
    "doctrine/dbal": "^3.5",
    "firebase/php-jwt": "^7.0.5",
    "illuminate/database": "^10.40",
    "illuminate/events": "^10.42",
    "illuminate/filesystem": "^10.49",
    "illuminate/hashing": "^10.42",
    "illuminate/pagination": "^10.48",
    "illuminate/support": "^10.48",
    "illuminate/validation": "^10.40",
    "intervention/image": "^3.11.1",
    "league/flysystem": "^3.0.16",
    "league/flysystem-local": "^3.15",
    "league/flysystem-path-prefixing": "^3.3",
    "league/flysystem-read-only": "^3.3",
    "monolog/monolog": "^3.9",
    "morilog/jalali": "^3.4",
    "nelexa/zip": "^4.0.2",
    "nette/php-generator": "^v4.1.7",
    "phpoption/phpoption": "^1.9",
    "predis/predis": "^2.2",
    "symfony/asset": "^v6.4.0",
    "symfony/cache": "^7.2",
    "symfony/console": "^v6.4.0",
    "symfony/dependency-injection": "^v6.4.0",
    "symfony/dotenv": "^v6.4.0",
    "symfony/error-handler": "^v6.4.0",
    "symfony/filesystem": "^v6.4.0",
    "symfony/finder": "^v6.4.0",
    "symfony/http-client": "^v6.4.0",
    "symfony/http-foundation": "^v6.4.0",
    "symfony/http-kernel": "^v6.4.0",
    "symfony/process": "^v6.4.0",
    "symfony/property-access": "^v6.4.0",
    "symfony/routing": "^v6.4.0",
    "symfony/serializer": "^v6.4.0",
    "symfony/templating": "^v6.4.0",
    "symfony/var-dumper": "^v6.4.0",
    "twig/twig": "^3",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "Pinoox\\": ""
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "nikic/php-parser": "^v4.19.4",
    "pestphp/pest": "^v1.23.1",
    "nunomaduro/collision": "^v6.4.0"
  },
  "scripts": {
    "test": "@php vendor/bin/pest --configuration=phpunit.xml",
    "test:ci": "@php vendor/bin/pest --configuration=phpunit.xml --exclude-group=non-isolated",
    "test:unit": "@php vendor/bin/pest --configuration=phpunit.xml --testsuite=Unit",
    "pincore": "@php bin/pincore"
  },
  "bin": [
    "bin/pincore"
  ],
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "suggest": {
    "ext-pdo_mysql": "Required when DB_CONNECTION is mysql or mariadb",
    "ext-pdo_pgsql": "Required when DB_CONNECTION is pgsql",
    "ext-pdo_sqlite": "Required when DB_CONNECTION is sqlite",
    "ext-pdo_sqlsrv": "Required when DB_CONNECTION is sqlsrv",
    "ext-zip": "Required for Pinx package build and install (.pinx)"
  },
  "minimum-stability": "dev",
  "extra": {
    "branch-alias": {
      "dev-master": "3.0.x-dev"
    }
  },
  "prefer-stable": true
}
