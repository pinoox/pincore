<!doctype html>
<html lang="{{ locale|default('en') }}" dir="{{ dir|default('ltr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>{{ t('no-app.page.title') }}</title>
    <link rel="stylesheet" href="{{ url('~pincore/resource/views/no-route/css/style.css') }}">
    <link rel="stylesheet" href="{{ url('~pincore/resource/views/no-app/css/extras.css') }}">
    {% if locale == 'fa' %}
        <link rel="stylesheet" href="{{ url('~pincore/resource/views/no-route/css/fonts-kalameh.css') }}">
    {% endif %}
</head>
<body>
<div class="app">
    {% if locales|length > 1 %}
        <div class="lang-bar">
            <label for="help-lang">{{ t('no-app.labels.language') }}</label>
            <select id="help-lang" class="lang-select" aria-label="{{ t('no-app.labels.language') }}">
                {% for code, name in locales %}
                    <option value="{{ code }}"{% if code == locale %} selected{% endif %}>{{ name }}</option>
                {% endfor %}
            </select>
        </div>
    {% endif %}

    <div class="page">
        <section class="page__message">
            <div class="image">
                <img src="{{ url('~pincore/resource/images/logo.png') }}" alt="Pinoox">
            </div>

            <div class="title">
                <span>{{ t('no-app.page.welcome_prefix') }}</span>
                <h2>Pinoox</h2>
                {% if t('no-app.page.welcome_suffix') %}
                    <span>{{ t('no-app.page.welcome_suffix') }}</span>
                {% endif %}
            </div>

            <div class="text">
                <div class="path" dir="ltr">{{ routePath|default('/') }}</div>
                <p class="description">{{ t('no-app.page.descriptions.' ~ resolution) }}</p>

                {% if routePackage %}
                    <div class="route-mapping" dir="ltr">
                        <span class="route-mapping__label">{{ t('no-app.page.labels.route_mapping') }}</span>
                        <code>{{ routePath }} → {{ routePackage }}</code>
                    </div>
                {% endif %}

                <div class="quick-start">
                    <h3>{{ t('no-app.page.quick_start_title') }}</h3>
                    <ol class="quick-start__steps">
                        <li>{{ t('no-app.page.steps.' ~ resolution ~ '.step1', {
                            package: routePackage|default('com_vendor_myapp')
                        })|raw }}</li>
                        <li>{{ t('no-app.page.steps.' ~ resolution ~ '.step2', {
                            package: routePackage|default('com_vendor_myapp')
                        })|raw }}</li>
                    </ol>

                    {% if cliExample %}
                        <p class="route-mapping__label">{{ t('no-app.page.labels.cli_title') }}</p>
                        <div class="code-box" dir="ltr">
                            <pre><code>{{ cliExample }}</code></pre>
                        </div>
                    {% endif %}

                    <div class="action-links">
                        {% if managerRoutesUrl %}
                            <a class="docs-btn docs-btn--secondary" href="{{ managerRoutesUrl }}">
                                {{ t('no-app.page.labels.manager_routes') }}
                            </a>
                        {% endif %}
                        {% if managerAppsUrl and resolution == 'app_disabled' %}
                            <a class="docs-btn docs-btn--secondary" href="{{ managerAppsUrl }}">
                                {{ t('no-app.page.labels.manager_apps') }}
                            </a>
                        {% endif %}
                        <a class="docs-btn" href="https://pinoox.com/docs" target="_blank" rel="noopener">
                            {{ t('no-app.page.docs_link') }}
                        </a>
                    </div>
                </div>
            </div>
        </section>

        <section class="page__help">
            <div class="page__help-content">
                <div class="content-item">
                    <div class="icon icon--docs" aria-hidden="true"></div>
                    <div class="caption">{{ t('no-app.help.docs') }}</div>
                    <div class="links">
                        <a href="https://pinoox.com/docs" target="_blank" rel="noopener">{{ t('no-app.help.guides') }}</a>
                        <a href="https://pinoox.com/docs" target="_blank" rel="noopener">{{ t('no-app.help.api') }}</a>
                    </div>
                </div>

                <div class="content-item">
                    <div class="icon icon--tutorial" aria-hidden="true"></div>
                    <div class="caption">{{ t('no-app.help.tutorials') }}</div>
                    <div class="links">
                        <a href="https://pinoox.com/developer" target="_blank" rel="noopener">{{ t('no-app.help.first_app') }}</a>
                    </div>
                </div>

                <div class="content-item">
                    <div class="icon icon--community" aria-hidden="true"></div>
                    <div class="caption">{{ t('no-app.help.community') }}</div>
                    <div class="links">
                        <a href="https://pinoox.com/faq" target="_blank" rel="noopener">{{ t('no-app.help.faq') }}</a>
                        <a href="https://pinoox.com" target="_blank" rel="noopener">{{ t('no-app.help.contact') }}</a>
                        <a href="https://t.me/pinoox" target="_blank" rel="noopener">{{ t('no-app.help.telegram') }}</a>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

{% if locales|length > 1 %}
<script>
(function () {
    var select = document.getElementById('help-lang');
    if (!select) {
        return;
    }

    select.addEventListener('change', function () {
        var url = new URL(window.location.href);
        url.searchParams.set('lang', select.value);
        window.location.href = url.toString();
    });
})();
</script>
{% endif %}
</body>
</html>
